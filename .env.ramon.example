# RAMON - plantilla de entorno. Copiar a .env.ramon.local (gitignored).

# ===== Brain cascada (nivel 1 -> 2 -> 3) =====

# Nivel 1: PC local (Ollama qwen2.5:14b, mejor calidad, coste 0)
PC_OLLAMA_URL=
PC_OLLAMA_MODEL=qwen2.5:14b

# Nivel 2: Gemini 2.5 Flash (cuota free hasta que se agote)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Nivel 3: VPS Ollama (backup pequeno siempre-on)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ===== Google (hub ARTES-BUHO_API-GOOGLE) =====
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_WORKSPACE_EMAIL=booking@artesbuhomanagement.com

# ===== Drive / Sheets / Folders ARTES BUHO =====
DRIVE_FOLDER_RAMON=
CRM_ROSTER_SHEET_ID=
PROMOTORES_FOLDER_ID=
LOGOS_ARTISTAS_FOLDER_ID=
CONTRATOS_FOLDER_ID=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Holded (factuacion agencia) =====
HOLDED_API_KEY=

# ===== Firma digital (hub ARTES-BUHO_FIRMA-DIGITAL) =====
FIRMA_DIGITAL_URL=
FIRMA_DIGITAL_API_KEY=

# ===== Runtime =====
RAMON_ENV=local
LOG_LEVEL=INFO
